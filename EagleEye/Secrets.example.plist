<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template for Secrets.plist.

  Secrets.plist is gitignored so real keys never reach GitHub. To set up:
    1. Copy this file to "Secrets.plist" in the same folder.
    2. Replace the placeholder below with your Congress.gov API key
       (get one free at https://api.congress.gov/sign-up/).

  Until a real key is present, the app falls back to bundled sample data.
-->
<plist version="1.0">
<dict>
	<key>CongressGovAPIKey</key>
	<string>YOUR_CONGRESS_GOV_API_KEY</string>
</dict>
</plist>
